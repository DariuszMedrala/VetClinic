# =====================================================================
# VetClinic — szablon zmiennych środowiskowych
# Skopiuj do pliku .env i uzupełnij własnymi wartościami:
#   cp .env.example .env
# Plik .env jest ignorowany przez git (zawiera sekrety lokalne).
# =====================================================================

# --- Baza danych PostgreSQL (konsumowane przez obraz postgres) ---
POSTGRES_DB=vetclinic
POSTGRES_USER=vetclinic
POSTGRES_PASSWORD=zmien_mnie_lokalnie

# --- Połączenie aplikacji PHP z bazą (host/port w sieci dockera) ---
# Nazwa i hasło bazy aplikacja czyta z POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB
DB_HOST=db
DB_PORT=5432

# --- pgAdmin (panel administracyjny bazy) ---
PGADMIN_DEFAULT_EMAIL=admin@vetclinic.local
PGADMIN_DEFAULT_PASSWORD=admin
